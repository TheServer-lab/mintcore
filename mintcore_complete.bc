MINTCORE_ADMIN_KEY=admin-secret
MINTCORE_DB_URL=sqlite:///./mintcore.db
MINTCORE_TREASURY=treasury
MINTCORE_INTEREST_RATE=5
MINTCORE_DEBT_CAP=-1000
MINTCORE_CACHE_TTL=300
---

make-file ".gitignore" with ---
.env
__pycache__/
*.py[cod]
*.db
dist/
*.egg-info/
.eggs/
---

