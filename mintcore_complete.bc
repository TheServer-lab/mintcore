# ============================================================
# MintCore — Complete All-in-One Scaffold
# One file. No manual copying. No missing pieces.
# Run: bytecraft mintcore_complete.bc
# ============================================================

strict on

set project "mintcore-pkg"
set version "1.0.0"

print "Scaffolding MintCore complete package..."

set-working-folder "{{project}}"

# ── Folder structure ─────────────────────────────────────────
make-folder "src/mintcore"
make-folder "src/mintcore/routers"
make-folder "src/mintcore/bot"
make-folder "src/mintcore/bot/cogs"
make-folder "tests"
make-folder "docs"

# ============================================================
# pyproject.toml
# ============================================================

make-file "pyproject.toml" with ---
[build-system]
requires      = ["hatchling"]
build-backend = "hatchling.build"

[project]
name        = "mintcore"
version     = "1.0.0"
description = "Centralized virtual currency engine for game economies"
readme      = "README.md"
license     = { text = "SOCL-1.0" }
requires-python = ">=3.10"

authors = [
  { name = "Sourasish Das" },
]

keywords = [
  "game economy", "virtual currency", "fastapi",
  "currency engine", "mintcore",
]

classifiers = [
  "Development Status :: 4 - Beta",
  "Intended Audience :: Developers",
  "License :: Other/Proprietary License",
  "Programming Language :: Python :: 3",
  "Programming Language :: Python :: 3.10",
  "Programming Language :: Python :: 3.11",
  "Programming Language :: Python :: 3.12",
  "Topic :: Games/Entertainment",
  "Topic :: Software Development :: Libraries :: Python Modules",
  "Framework :: FastAPI",
]

dependencies = [
  "fastapi>=0.110.0",
  "uvicorn[standard]>=0.29.0",
  "sqlalchemy>=2.0.0",
  "pydantic>=2.0.0",
  "httpx>=0.27.0",
  "rich>=13.0.0",
  "typer>=0.12.0",
  "python-dotenv>=1.0.0",
]

[project.optional-dependencies]
bot = [
  "discord.py>=2.3.0",
]
dev = [
  "pytest>=8.0.0",
  "pytest-asyncio>=0.23.0",
  "hatch>=1.9.0",
  "twine>=5.0.0",
]

[project.scripts]
mintcore = "mintcore.cli:app"

[tool.hatch.build.targets.wheel]
packages = ["src/mintcore"]

[tool.pytest.ini_options]
testpaths    = ["tests"]
asyncio_mode = "auto"
---

