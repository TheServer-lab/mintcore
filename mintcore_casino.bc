make-file "games/roulette.py" with ---
import random
import time
from rich.console import Console
from rich.table import Table
from rich import box

console = Console()

NUMBERS = list(range(0, 37))   # 0-36 European roulette
REDS    = {1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36}
BLACKS  = set(NUMBERS) - REDS - {0}

BET_TYPES = {
    "number":  {"desc": "Exact number (0-36)",   "payout": 35},
    "red":     {"desc": "Red",                   "payout": 1},
    "black":   {"desc": "Black",                 "payout": 1},
    "odd":     {"desc": "Odd",                   "payout": 1},
    "even":    {"desc": "Even (not 0)",          "payout": 1},
    "low":     {"desc": "Low  (1-18)",           "payout": 1},
    "high":    {"desc": "High (19-36)",          "payout": 1},
}

def _color(n: int) -> str:
    if n == 0:   return "green"
    if n in REDS: return "red"
    return "black"

def _check_win(bet_type: str, value, result: int) -> bool:
    if bet_type == "number": return result == int(value)
    if bet_type == "red":    return result in REDS
    if bet_type == "black":  return result in BLACKS
    if bet_type == "odd":    return result != 0 and result % 2 == 1
    if bet_type == "even":   return result != 0 and result % 2 == 0
    if bet_type == "low":    return 1 <= result <= 18
    if bet_type == "high":   return 19 <= result <= 36
    return False

def animate_wheel(console: Console):
    for _ in range(14):
        n = random.randint(0, 36)
        col = _color(n)
        console.print(f"  🎡  [{col} bold]{n:>2}[/]", end="\r")
        time.sleep(0.08)

def play(player_id: str, bet: int, bet_type: str, value, api) -> dict:
    chips = api.get_chips(player_id)
    if chips < bet:
        console.print(f"[red]Not enough chips! You have {chips} CHIP.[/]")
        return {"played": False}

    if bet_type not in BET_TYPES:
        console.print(f"[red]Unknown bet type.[/]")
        return {"played": False}

    r = api.place_bet(player_id, bet)
    if "detail" in r:
        console.print(f"[red]Bet failed: {r['detail']}[/]")
        return {"played": False}

    console.print("\n[bold yellow]🎡 Spinning the wheel...[/]")
    animate_wheel(console)

    result  = random.randint(0, 36)
    color   = _color(result)
    parity  = "even" if result % 2 == 0 else "odd"
    col_str = f"[{color} bold]{result}[/]"

    console.print(f"\n  Ball lands on {col_str} ({color}, {parity})")

    won      = _check_win(bet_type, value, result)
    payout_m = BET_TYPES[bet_type]["payout"]
    winnings = int(bet * (payout_m + 1)) if won else 0

    if won:
        api.pay_winnings(player_id, winnings)
        profit = winnings - bet
        console.print(f"[green]  You win! +{profit} CHIP[/]")
    else:
        console.print(f"[red]  You lose. -{bet} CHIP[/]")

    return {"played": True, "result": result, "won": won,
            "bet": bet, "winnings": winnings}

def show_bet_types():
    t = Table("Bet type", "Description", "Payout", box=box.SIMPLE)
    for k, v in BET_TYPES.items():
        t.add_row(k, v["desc"], f"×{v['payout']+1}")
    console.print(t)
---

