make-file "games/dice.py" with ---
import random
import time
from rich.console import Console

console = Console()

DICE_FACES = {1: "⚀", 2: "⚁", 3: "⚂", 4: "⚃", 5: "⚄", 6: "⚅"}
PAYOUT     = 5   # net payout multiplier on exact hit (6x gross)

def animate_roll(console: Console):
    for _ in range(10):
        n = random.randint(1, 6)
        console.print(f"  {DICE_FACES[n]}  {n}", end="\r")
        time.sleep(0.09)

def play(player_id: str, bet: int, pick: int, api) -> dict:
    if pick not in range(1, 7):
        console.print("[red]Pick a number from 1 to 6.[/]")
        return {"played": False}

    chips = api.get_chips(player_id)
    if chips < bet:
        console.print(f"[red]Not enough chips! You have {chips} CHIP.[/]")
        return {"played": False}

    r = api.place_bet(player_id, bet)
    if "detail" in r:
        console.print(f"[red]Bet failed: {r['detail']}[/]")
        return {"played": False}

    console.print(f"\n[bold yellow]🎲 Rolling... (you picked {DICE_FACES[pick]} {pick})[/]")
    animate_roll(console)

    result   = random.randint(1, 6)
    won      = result == pick
    winnings = bet * (PAYOUT + 1) if won else 0

    console.print(f"\n  Dice shows: [bold cyan]{DICE_FACES[result]} {result}[/]")

    if won:
        api.pay_winnings(player_id, winnings)
        profit = winnings - bet
        console.print(f"[green]  Exact hit! +{profit} CHIP  (×{PAYOUT+1})[/]")
    else:
        console.print(f"[red]  No match. -{bet} CHIP[/]")

    return {"played": True, "result": result, "won": won,
            "bet": bet, "winnings": winnings}
