# ============================================================
# casino.py  — main game loop
# ============================================================

make-file "casino.py" with ---
"""
MintCore Casino — CLI
Requires: MintCore API running on http://127.0.0.1:8000

Usage:
    python casino.py
    python casino.py --player myname
"""
import sys
import argparse
from rich.console import Console
from rich.panel   import Panel
from rich.table   import Table
from rich.prompt  import Prompt, IntPrompt
from rich         import box
import httpx

import api as mc
from config import CURRENCY, WELCOME_BONUS
from games import slots, roulette, coinflip, dice

console = Console()

# ── Startup ───────────────────────────────────────────────────

def check_api():
    try:
        httpx.get(f"http://127.0.0.1:8000/", timeout=3.0).raise_for_status()
    except Exception:
        console.print(Panel(
            "[red]Cannot reach MintCore API at http://127.0.0.1:8000[/]\n\n"
            "Start it first:\n"
            "  [bold]mintcore start[/]  or  [bold]py -m mintcore.cli start[/]",
            title="API Offline", border_style="red"))
        sys.exit(1)

def setup_player(player_id: str) -> int:
    mc.ensure_user(player_id)
    mc.ensure_currency()
    chips = mc.get_chips(player_id)
    if chips == 0:
        console.print(f"[cyan]Welcome bonus: +{WELCOME_BONUS} CHIP[/]")
        mc.mint_welcome(player_id, WELCOME_BONUS)
        chips = WELCOME_BONUS
    return chips

# ── UI helpers ────────────────────────────────────────────────

def show_banner():
    console.print(Panel(
        "[bold yellow]🎰  MintCore Casino  🎰[/]\n"
        "[dim]Powered by MintCore virtual currency engine[/]",
        border_style="yellow", expand=False))

def show_balance(player_id: str):
    chips = mc.get_chips(player_id)
    console.print(f"\n  [bold]Balance:[/] [yellow]{chips:,} CHIP[/]\n")
    return chips

def show_menu():
    t = Table(box=box.SIMPLE, show_header=False)
    t.add_row("[cyan]1[/]", "🎰  Slots")
    t.add_row("[cyan]2[/]", "🎡  Roulette")
    t.add_row("[cyan]3[/]", "🪙  Coin Flip")
    t.add_row("[cyan]4[/]", "🎲  Dice Roll")
    t.add_row("[cyan]5[/]", "📒  View ledger")
    t.add_row("[cyan]6[/]", "🚪  Quit")
    console.print(t)

def get_bet(player_id: str, max_bet: int) -> int | None:
    chips = mc.get_chips(player_id)
    if chips <= 0:
        console.print("[red]You're out of chips! Game over.[/]")
        return None
    while True:
        try:
            bet = IntPrompt.ask(f"  Bet amount (1–{min(chips, max_bet)})")
            if 1 <= bet <= min(chips, max_bet):
                return bet
            console.print(f"[red]  Enter a value between 1 and {min(chips, max_bet)}[/]")
        except (ValueError, KeyboardInterrupt):
            return None

def show_ledger(player_id: str):
    txs = mc.get_ledger(player_id)
    if not txs:
        console.print("  [dim]No transactions yet.[/]")
        return
    t = Table("Type", "Amount", "From", "To", "Time", box=box.SIMPLE)
    for tx in txs[:12]:
        kind = tx["type"].upper()
        amt  = str(tx["amount"])
        frm  = tx["from_user"]
        to   = tx["to_user"]
        ts   = str(tx.get("timestamp", ""))[:16]
        t.add_row(kind, amt, frm, to, ts)
    console.print(t)

# ── Game dispatchers ──────────────────────────────────────────

def play_slots(player_id: str):
    console.print("\n[bold]🎰 Slots[/]  — match symbols to win")
    bet = get_bet(player_id, 500)
    if bet is None: return
    slots.play(player_id, bet, mc)

def play_roulette(player_id: str):
    console.print("\n[bold]🎡 Roulette[/]  — bet on where the ball lands")
    roulette.show_bet_types()
    bet_type = Prompt.ask("  Bet type", choices=list(roulette.BET_TYPES.keys()))
    value    = None
    if bet_type == "number":
        value = IntPrompt.ask("  Pick a number (0-36)")
        if not (0 <= value <= 36):
            console.print("[red]Invalid number.[/]")
            return
    bet = get_bet(player_id, 1000)
    if bet is None: return
    roulette.play(player_id, bet, bet_type, value, mc)

def play_coinflip(player_id: str):
    console.print("\n[bold]🪙 Coin Flip[/]  — double or nothing")
    choice = Prompt.ask("  Heads or Tails?", choices=["H", "T", "Heads", "Tails"])
    bet    = get_bet(player_id, 2000)
    if bet is None: return
    coinflip.play(player_id, bet, choice, mc)

def play_dice(player_id: str):
    console.print("\n[bold]🎲 Dice Roll[/]  — pick 1-6, hit it for ×6")
    pick = IntPrompt.ask("  Your number (1-6)")
    if pick not in range(1, 7):
        console.print("[red]Pick between 1 and 6.[/]")
        return
    bet = get_bet(player_id, 500)
    if bet is None: return
    dice.play(player_id, bet, pick, mc)

# ── Main loop ─────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="MintCore Casino")
    parser.add_argument("--player", default=None, help="Player ID")
    args = parser.parse_args()

    check_api()
    show_banner()

    player_id = args.player or Prompt.ask("  [cyan]Enter your player name[/]")
    chips     = setup_player(player_id)

    console.print(f"\n  Welcome, [bold cyan]{player_id}[/]! You have [yellow]{chips:,} CHIP[/].")

    ACTIONS = {
        "1": play_slots,
        "2": play_roulette,
        "3": play_coinflip,
        "4": play_dice,
    }

    while True:
        show_balance(player_id)
        show_menu()

        choice = Prompt.ask("  Choose", choices=["1","2","3","4","5","6"])

        if choice == "6":
            final = mc.get_chips(player_id)
            console.print(f"\n  Thanks for playing, [bold]{player_id}[/]!")
            console.print(f"  Final balance: [yellow]{final:,} CHIP[/]")
            break
        elif choice == "5":
            show_ledger(player_id)
        elif choice in ACTIONS:
            ACTIONS[choice](player_id)

        chips = mc.get_chips(player_id)
        if chips <= 0:
            console.print(Panel(
                "[red bold]💸 You're broke![/]\n\n"
                "Come back tomorrow for another welcome bonus.",
                border_style="red"))
            break

if __name__ == "__main__":
    main()
---

# ============================================================
# README.md
# ============================================================

make-file "README.md" with ---
# MintCore Casino

A CLI casino powered by the MintCore virtual currency engine.

## Requirements

- MintCore API running (`mintcore start` or `py -m mintcore.cli start`)
- Python 3.10+

## Install & run

```bash
pip install -r requirements.txt
python casino.py
python casino.py --player yourname
```

## Games

| Game      | Win condition         | Max payout |
|-----------|-----------------------|------------|
| 🎰 Slots  | Match 3 symbols       | ×50 (💎💎💎) |
| 🎡 Roulette | Bet on number/color | ×36 (exact number) |
| 🪙 Coin Flip | Pick heads/tails  | ×2 |
| 🎲 Dice Roll | Pick exact number | ×6 |

## How it works

All bets and winnings flow through the MintCore API as real
currency transfers — so everything is recorded in the ledger.
New players receive a 100 CHIP welcome bonus on first launch.
---

