make-folder "games"
make-file "games/__init__.py" with ""

# ============================================================
# games/slots.py
# ============================================================

make-file "games/slots.py" with ---
import random
import time
from rich.console import Console
from rich.table import Table
from rich import box

console = Console()

REELS   = ["🍒", "🍋", "🍊", "🍇", "⭐", "💎", "7️⃣"]
WEIGHTS = [30,   25,   20,   15,   6,    3,    1  ]

PAYOUTS = {
    ("💎", "💎", "💎"): 50,
    ("7️⃣", "7️⃣", "7️⃣"): 25,
    ("⭐", "⭐", "⭐"): 10,
    ("🍇", "🍇", "🍇"): 6,
    ("🍊", "🍊", "🍊"): 4,
    ("🍋", "🍋", "🍋"): 3,
    ("🍒", "🍒", "🍒"): 2,
}
PARTIAL_CHERRY = 0.5   # multiplier for exactly 2 cherries

def spin() -> list[str]:
    return random.choices(REELS, weights=WEIGHTS, k=3)

def get_multiplier(reels: list[str]) -> float:
    combo = tuple(reels)
    if combo in PAYOUTS:
        return PAYOUTS[combo]
    if reels.count("🍒") == 2:
        return PARTIAL_CHERRY
    return 0

def animate_spin(console: Console):
    frames = 12
    for i in range(frames):
        interim = random.choices(REELS, weights=WEIGHTS, k=3)
        console.print(
            f"  [ {'  '.join(interim)} ]",
            end="\r", style="bold yellow"
        )
        time.sleep(0.07)

def play(player_id: str, bet: int, api) -> dict:
    from rich.panel import Panel

    chips = api.get_chips(player_id)
    if chips < bet:
        console.print(f"[red]Not enough chips! You have {chips} CHIP.[/]")
        return {"played": False}

    r = api.place_bet(player_id, bet)
    if "detail" in r:
        console.print(f"[red]Bet failed: {r['detail']}[/]")
        return {"played": False}

    console.print("\n[bold yellow]🎰 Spinning...[/]")
    animate_spin(console)

    reels      = spin()
    multiplier = get_multiplier(reels)
    winnings   = int(bet * multiplier)

    console.print(f"\n  [bold white][ {'  '.join(reels)} ][/]")

    if winnings > 0:
        api.pay_winnings(player_id, winnings)
        profit = winnings - bet
        if multiplier >= 10:
            console.print(Panel(
                f"[bold green]JACKPOT! 🎉  +{profit} CHIP[/]",
                border_style="green"))
        else:
            console.print(f"[green]  Winner! ×{multiplier}  →  +{profit} CHIP[/]")
    else:
        console.print(f"[red]  No match. -{bet} CHIP[/]")

    # payout table
    t = Table(box=box.SIMPLE, show_header=True)
    t.add_column("Combo",     style="cyan")
    t.add_column("Pays",      justify="right")
    for combo, mult in PAYOUTS.items():
        t.add_row("  ".join(combo), f"×{mult}")
    t.add_row("🍒 🍒 any", f"×{PARTIAL_CHERRY}")
    console.print(t)

    return {"played": True, "reels": reels, "multiplier": multiplier,
            "bet": bet, "winnings": winnings}
---

# ============================================================
# games/roulette.py
