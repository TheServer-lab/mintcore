make-file "games/coinflip.py" with ---
import random
import time
from rich.console import Console

console = Console()

def animate_flip(console: Console):
    frames = ["🪙 H", "🪙 T", "🪙 H", "🪙 T", "🪙 H", "🪙 T"]
    for f in frames:
        console.print(f"  {f}", end="\r")
        time.sleep(0.12)

def play(player_id: str, bet: int, choice: str, api) -> dict:
    choice = choice.upper()
    if choice not in ("H", "T", "HEADS", "TAILS"):
        console.print("[red]Choose H/Heads or T/Tails.[/]")
        return {"played": False}

    chips = api.get_chips(player_id)
    if chips < bet:
        console.print(f"[red]Not enough chips! You have {chips} CHIP.[/]")
        return {"played": False}

    r = api.place_bet(player_id, bet)
    if "detail" in r:
        console.print(f"[red]Bet failed: {r['detail']}[/]")
        return {"played": False}

    console.print("\n[bold yellow]🪙 Flipping...[/]")
    animate_flip(console)

    result   = random.choice(["H", "T"])
    result_s = "Heads" if result == "H" else "Tails"
    pick_s   = "Heads" if choice[0] == "H" else "Tails"
    won      = choice[0] == result
    winnings = bet * 2 if won else 0

    console.print(f"\n  Coin shows: [bold cyan]{result_s}[/]  (you picked {pick_s})")

    if won:
        api.pay_winnings(player_id, winnings)
        console.print(f"[green]  You win! +{bet} CHIP[/]")
    else:
        console.print(f"[red]  You lose. -{bet} CHIP[/]")

    return {"played": True, "result": result_s, "won": won,
            "bet": bet, "winnings": winnings}
