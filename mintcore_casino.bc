# config.py
# ============================================================

make-file "config.py" with ---
MINTCORE_URL      = "http://127.0.0.1:8000"
MINTCORE_ADMIN_KEY = "admin-secret"
CURRENCY           = "CHIP"
CURRENCY_NAME      = "Casino Chips"
CURRENCY_SYMBOL    = "C"
WELCOME_BONUS      = 100
HOUSE_ID           = "casino_house"
ADMIN_HEADERS      = {"X-Admin-Key": MINTCORE_ADMIN_KEY}
---

# ============================================================
# api.py  — thin wrapper around MintCore REST API
# ============================================================

make-file "api.py" with ---
"""All MintCore API calls in one place."""
import httpx
from config import MINTCORE_URL, ADMIN_HEADERS, CURRENCY, HOUSE_ID

_client = httpx.Client(base_url=MINTCORE_URL, timeout=10.0)

def _post(path, json=None, headers=None):
    r = _client.post(path, json=json, headers=headers or {})
    return r.json()

def _get(path):
    r = _client.get(path)
    return r.json()

def ensure_currency():
    """Create CHIP currency and house account if they don't exist."""
    _post("/admin/currency", {
        "currency_id": CURRENCY,
        "name":        "Casino Chips",
        "symbol":      "C",
    }, ADMIN_HEADERS)
    ensure_user(HOUSE_ID)
    # Seed house with a large float so it can always pay winnings
    bal = get_balance(HOUSE_ID)
    if bal.get("wallets", {}).get(CURRENCY, 0) < 500_000:
        _post("/admin/mint", {
            "to":          HOUSE_ID,
            "amount":      1_000_000,
            "currency_id": CURRENCY,
        }, ADMIN_HEADERS)

def ensure_user(user_id: str) -> dict:
    return _post("/users", {"user_id": user_id})

def get_balance(user_id: str) -> dict:
    return _get(f"/users/{user_id}/balance")

def get_chips(user_id: str) -> int:
    data = get_balance(user_id)
    return data.get("wallets", {}).get(CURRENCY, 0)

def mint_welcome(user_id: str, amount: int):
    _post("/admin/mint", {
        "to":          user_id,
        "amount":      amount,
        "currency_id": CURRENCY,
    }, ADMIN_HEADERS)

def place_bet(player_id: str, amount: int):
    """Player sends chips to house."""
    return _post("/transactions/transfer", {
        "from_user":   player_id,
        "to_user":     HOUSE_ID,
        "amount":      amount,
        "currency_id": CURRENCY,
    })

def pay_winnings(player_id: str, amount: int):
    """House sends chips to player."""
    return _post("/transactions/transfer", {
        "from_user":   HOUSE_ID,
        "to_user":     player_id,
        "amount":      amount,
        "currency_id": CURRENCY,
    })

def get_ledger(user_id: str) -> list:
    return _get(f"/ledger/{user_id}")
---

