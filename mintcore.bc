# ============================================================
# tests/test_engine.py
# ============================================================

make-file "tests/test_engine.py" with ---
"""
Smoke tests for MintCore.  Run with: pytest tests/
"""
from fastapi.testclient import TestClient
from main import app

client  = TestClient(app)
HEADERS = {"X-Admin-Key": "admin-secret"}

def _post(path, payload, headers=None):
    return client.post(path, json=payload, headers=headers or {})

def setup_module():
    _post("/admin/currency", {"currency_id": "GLD", "name": "Gold", "symbol": "G"}, HEADERS)
    _post("/users", {"user_id": "alice"})
    _post("/users", {"user_id": "bob"})

def test_mint_and_balance():
    _post("/admin/mint", {"to": "alice", "amount": 500, "currency_id": "GLD"}, HEADERS)
    r = client.get("/users/alice/balance")
    assert r.status_code == 200
    assert r.json()["wallets"]["GLD"] == 500

def test_transfer():
    r = _post("/transactions/transfer", {
        "from_user": "alice", "to_user": "bob",
        "amount": 100, "currency_id": "GLD",
    })
    assert r.status_code == 200
    assert r.json()["from_balance"] == 400

def test_debt_cap():
    r = _post("/transactions/transfer", {
        "from_user": "bob", "to_user": "alice",
        "amount": 5000, "currency_id": "GLD",
    })
    assert r.status_code == 400
    assert r.json()["detail"] == "DEBT_LIMIT_EXCEEDED"

def test_tax():
    r = _post("/admin/tax", {"percentage": 10, "currency_id": "GLD"}, HEADERS)
    assert r.status_code == 200
    assert r.json()["status"] == "tax_applied"

def test_loan_and_repay():
    _post("/admin/mint", {"to": "bob", "amount": 300, "currency_id": "GLD"}, HEADERS)
    _post("/admin/loan", {"user_id": "bob", "amount": 200, "currency_id": "GLD"}, HEADERS)
    r = client.post("/repay", json={"user_id": "bob", "amount": 200, "currency_id": "GLD"})
    assert r.status_code == 200
    assert r.json()["remaining_debt"] == 0

def test_supply_analytics():
    r = client.get("/analytics/supply")
    assert "supply" in r.json()

def test_stats():
    r = client.get("/analytics/stats")
    body = r.json()
    assert "user_count" in body
    assert "total_tx" in body
